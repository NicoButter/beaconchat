{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "BeaconChat: Deploy to Phone (Full)",
            "type": "shell",
            "command": "${workspaceFolder}/deploy-to-phone.sh",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "BeaconChat: Quick Deploy (No Build)",
            "type": "shell",
            "command": "${workspaceFolder}/quick-deploy.sh",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "BeaconChat: Build APK Only",
            "type": "shell",
            "command": "export JAVA_HOME=/usr/lib/jvm/java-21-openjdk && export PATH=$JAVA_HOME/bin:$PATH && ./gradlew assembleDebug",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": []
        },
        {
            "label": "BeaconChat: Check Connected Devices",
            "type": "shell",
            "command": "adb devices -l",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "BeaconChat: View Logcat",
            "type": "shell",
            "command": "adb logcat -c && adb logcat -s 'BeaconChat:*' '*:E'",
            "isBackground": true,
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated"
            },
            "problemMatcher": []
        },
        {
            "label": "BeaconChat: Uninstall from Phone",
            "type": "shell",
            "command": "adb uninstall com.nicobutter.beaconchat",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
